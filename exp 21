#include <stdio.h>

int main() {
    int block[5]={100,500,200,300,600};
    int process[4]={212,417,112,426};

    for(int i=0;i<4;i++) {
        int worst = -1;
        for(int j=0;j<5;j++) {
            if(block[j] >= process[i]) {
                if(worst == -1 || block[j] > block[worst])
                    worst = j;
            }
        }
        if(worst != -1) {
            printf("P%d -> Block %d\n",i+1,worst+1);
            block[worst] -= process[i];
        }
    }
    return 0;
}
