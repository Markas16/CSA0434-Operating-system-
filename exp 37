#include <stdio.h>

int main() {
    int req[10], n, head, total=0;

    scanf("%d",&n);
    for(int i=0;i<n;i++) scanf("%d",&req[i]);

    scanf("%d",&head);

    for(int i=0;i<n;i++) {
        total += abs(req[i]-head);
        head = req[i];
    }

    printf("Total Seek Time: %d\n", total);
    return 0;
}
