// Q8: Round Robin Scheduling
#include <stdio.h>

int main() {
    int n, q;
    printf("Enter number of processes: ");
    scanf("%d", &n);
    printf("Enter time quantum: ");
    scanf("%d", &q);

    int pid[50], at[50], bt[50], rt[50], ct[50];

    for (int i = 0; i < n; i++) {
        pid[i] = i + 1;
        printf("P%d Arrival Time: ", pid[i]); scanf("%d", &at[i]);
        printf("P%d Burst Time  : ", pid[i]); scanf("%d", &bt[i]);
        rt[i] = bt[i];
        ct[i] = 0;
    }

    int queue[1000], front = 0, rear = 0;
    int inQ[50] = {0};
    int completed = 0, time = 0;

    // add processes arrived at time 0
    for (int i = 0; i < n; i++) {
        if (at[i] == 0) {
            queue[rear++] = i;
            inQ[i] = 1;
        }
    }

    printf("\nGantt Chart:\n|");

    while (completed < n) {
        if (front == rear) {
            // CPU idle: jump to next arrival
            int nextAt = 1000000;
            for (int i = 0; i < n; i++) {
                if (rt[i] > 0 && at[i] > time && at[i] < nextAt) nextAt = at[i];
            }
            if (nextAt == 1000000) break;
            time = nextAt;

            for (int i = 0; i < n; i++) {
                if (rt[i] > 0 && at[i] <= time && !inQ[i]) {
                    queue[rear++] = i;
                    inQ[i] = 1;
                }
            }
            continue;
        }

        int idx = queue[front++];
        inQ[idx] = 0;

        printf(" P%d |", pid[idx]);

        int run = (rt[idx] < q) ? rt[idx] : q;
        rt[idx] -= run;
        time += run;

        // add newly arrived
        for (int i = 0; i < n; i++) {
            if (rt[i] > 0 && at[i] <= time && !inQ[i]) {
                queue[rear++] = i;
                inQ[i] = 1;
            }
        }

        if (rt[idx] > 0) {
            queue[rear++] = idx;
            inQ[idx] = 1;
        } else {
            ct[idx] = time;
            completed++;
        }
    }

    double sumWT = 0, sumTAT = 0;
    printf("\n\nProcess\tAT\tBT\tCT\tTAT\tWT\n");
    for (int i = 0; i < n; i++) {
        int tat = ct[i] - at[i];
        int wt = tat - bt[i];
        sumWT += wt;
        sumTAT += tat;
        printf("P%d\t%d\t%d\t%d\t%d\t%d\n", pid[i], at[i], bt[i], ct[i], tat, wt);
    }

    printf("\nAverage Waiting Time   = %.2f\n", sumWT / n);
    printf("Average Turnaround Time= %.2f\n", sumTAT / n);
    return 0;
}
