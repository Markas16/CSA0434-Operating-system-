#include <stdio.h>

struct emp {
    int id;
    char name[20];
} e;

int main() {
    FILE *fp;
    int n, pos;

    fp = fopen("emp.dat", "wb+");

    printf("Enter number of records: ");
    scanf("%d", &n);

    for(int i=0;i<n;i++) {
        printf("Enter id & name: ");
        scanf("%d %s", &e.id, e.name);
        fwrite(&e, sizeof(e), 1, fp);
    }

    printf("Enter position to read: ");
    scanf("%d", &pos);

    fseek(fp, (pos-1)*sizeof(e), SEEK_SET);
    fread(&e, sizeof(e), 1, fp);

    printf("Record: %d %s\n", e.id, e.name);

    fclose(fp);
    return 0;
}
