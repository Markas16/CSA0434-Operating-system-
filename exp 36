#include <stdio.h>

int main() {
    int blocks[10], n;

    printf("Enter number of blocks: ");
    scanf("%d",&n);

    printf("Enter blocks: ");
    for(int i=0;i<n;i++)
        scanf("%d",&blocks[i]);

    printf("Linked list: ");
    for(int i=0;i<n;i++)
        printf("%d -> ", blocks[i]);

    printf("NULL");
    return 0;
}
