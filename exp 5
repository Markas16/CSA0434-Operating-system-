// Q5: Non-preemptive Priority Scheduling
#include <stdio.h>

int main() {
    int n;
    printf("Enter number of processes: ");
    scanf("%d", &n);

    int pid[50], at[50], bt[50], pr[50], ct[50], tat[50], wt[50], done[50];

    for (int i = 0; i < n; i++) {
        pid[i] = i + 1;
        printf("P%d Arrival Time: ", pid[i]); scanf("%d", &at[i]);
        printf("P%d Burst Time  : ", pid[i]); scanf("%d", &bt[i]);
        printf("P%d Priority    : ", pid[i]); scanf("%d", &pr[i]);
        done[i] = 0;
    }

    int time = 0, completed = 0;
    double sumWT = 0, sumTAT = 0;

    printf("\nGantt Chart:\n|");

    while (completed < n) {
        int idx = -1, bestPr = 1000000;

        for (int i = 0; i < n; i++) {
            if (!done[i] && at[i] <= time) {
                if (pr[i] < bestPr) {
                    bestPr = pr[i];
                    idx = i;
                } else if (pr[i] == bestPr) {
                    if (at[i] < at[idx]) idx = i;
                }
            }
        }

        if (idx == -1) { time++; continue; }

        time += bt[idx];
        ct[idx] = time;
        tat[idx] = ct[idx] - at[idx];
        wt[idx] = tat[idx] - bt[idx];
        done[idx] = 1;
        completed++;

        printf(" P%d |", pid[idx]);
    }

    printf("\n\nProcess\tAT\tBT\tPR\tCT\tTAT\tWT\n");
    for (int i = 0; i < n; i++) {
        sumWT += wt[i];
        sumTAT += tat[i];
        printf("P%d\t%d\t%d\t%d\t%d\t%d\t%d\n",
               pid[i], at[i], bt[i], pr[i], ct[i], tat[i], wt[i]);
    }

    printf("\nAverage Waiting Time   = %.2f\n", sumWT / n);
    printf("Average Turnaround Time= %.2f\n", sumTAT / n);
    return 0;
}
