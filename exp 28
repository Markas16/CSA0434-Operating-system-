#include <stdio.h>
#include <string.h>

int main() {
    char line[100], word[20];
    FILE *fp = fopen("file.txt","r");

    printf("Enter word: ");
    scanf("%s", word);

    while(fgets(line,100,fp)) {
        if(strstr(line, word))
            printf("%s", line);
    }
    fclose(fp);
    return 0;
}
